---
import '../styles/global.css';
import TocDrawer from '../components/TocDrawer.astro';
import Lightbox from '../components/Lightbox.astro';
import ImageSlot from '../components/ImageSlot.astro';
interface Props { title: string; description?: string; }
const { title, description = 'A cross-referenced study of Kamba Ramayanam.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Kamba Ramayanam</title>
    <meta name="description" content={description} />
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script is:inline src="/pagefind/pagefind-ui.js"></script>
  </head>
  <body>
    <Lightbox />
    <header>
      <div class="site-banner">
        <div class="banner-perumal banner-perumal-l"><ImageSlot id="banner-perumal-left" label="Perumal" ratio="1/1" /></div>
        <a href="/" class="banner-link">
          <span class="banner-tamil" lang="ta">கம்பராமாயணம்</span>
          <span class="banner-title">Kamba Ramayanam</span>
          <span class="banner-tagline">A cross-referenced study through the Vishishtadvaita tradition</span>
        </a>
        <div class="banner-perumal banner-perumal-r"><ImageSlot id="banner-perumal-right" label="Perumal" ratio="1/1" /></div>
      </div>
      <nav>
        <button id="toc-toggle" class="nav-toc-btn" aria-label="Toggle contents">☰ Contents</button>
        <a href="/"><span class="nav-en">Home</span><span class="nav-ta" lang="ta">முகப்பு</span></a>
        <a href="/search"><span class="nav-en">Search</span><span class="nav-ta" lang="ta">தேடு</span></a>
        <a href="/kambar"><span class="nav-en">Kambar</span><span class="nav-ta" lang="ta">கம்பர்</span></a>
        <a href="/sarvasvam"><span class="nav-en">Sarvasvam</span><span class="nav-ta" lang="ta">சர்வஸ்வம்</span></a>
        <a href="/about"><span class="nav-en">About</span><span class="nav-ta" lang="ta">பற்றி</span></a>
      </nav>
    </header>
    <div class="layout">
      <TocDrawer />
      <main data-pagefind-body>
        <slot />
      </main>
    </div>
    <footer>
      <div id="search"></div>
      <p><small>kambaramayanam.org · content is AI-assisted and human-verified.</small></p>
    </footer>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (window.PagefindUI) new window.PagefindUI({ element: '#search', showsubResults: true });
      });
    </script>
  </body>
</html>
