---
import '../styles/global.css';
import TocDrawer from '../components/TocDrawer.astro';
import Lightbox from '../components/Lightbox.astro';
interface Props { title: string; description?: string; }
const { title, description = 'A cross-referenced study of Kamba Ramayanam.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Kamba Ramayanam</title>
    <meta name="description" content={description} />
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script is:inline src="/pagefind/pagefind-ui.js"></script>
  </head>
  <body>
    <TocDrawer />
    <Lightbox />
    <header>
      <div class="site-banner">
        <a href="/" class="banner-link">
          <span class="banner-tamil" lang="ta">கம்பராமாயணம்</span>
          <span class="banner-title">Kamba Ramayanam</span>
          <span class="banner-tagline">A cross-referenced study through the Vishishtadvaita tradition</span>
        </a>
      </div>
      <nav>
        <button id="toc-toggle" class="nav-toc-btn" aria-label="Open contents" aria-expanded="false" aria-controls="toc-drawer">☰ Contents</button>
        <a href="/">Home</a>
        <a href="/browse">Browse</a>
        <a href="/kambar">Kambar</a>
        <a href="/sarvasvam">Sarvasvam</a>
        <a href="/about">About</a>
      </nav>
    </header>
    <main data-pagefind-body>
      <slot />
    </main>
    <footer>
      <div id="search"></div>
      <p><small>kambaramayanam.org · content is AI-assisted and human-verified.</small></p>
    </footer>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (window.PagefindUI) new window.PagefindUI({ element: '#search', showsubResults: true });
      });
    </script>
  </body>
</html>
