---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DraftBanner from '../../components/DraftBanner.astro';
import { CATEGORY_COLLECTION, CATEGORIES, type Category } from '../../lib/categories';
import { assertWorkRefsResolve } from '../../lib/validate';

export async function getStaticPaths() {
  /** Strip .md / .mdx extension from Astro 5 content entry IDs for clean URL params and matching. */
  const stripExt = (id: string) => id.replace(/\.(md|mdx)$/, '');
  const sourceCollections = [...new Set(Object.values(CATEGORY_COLLECTION))];
  const verses = await getCollection('verses');

  // Build-time integrity check: every source record's work field must resolve.
  const worksEntries = await getCollection('works');
  const worksIds = new Set(worksEntries.map((w) => w.id));
  const allSourceEntries: { id: string; data: { work: string } }[] = [];
  for (const collection of sourceCollections) {
    const entries = (await getCollection(collection as any)) as any[];
    for (const e of entries) {
      allSourceEntries.push({ id: stripExt(e.id), data: { work: e.data.work } });
    }
  }
  assertWorkRefsResolve(allSourceEntries, (workId) => worksIds.has(workId));

  const paths: any[] = [];
  for (const collection of sourceCollections) {
    const entries = (await getCollection(collection as any)) as any[];
    const category = (CATEGORIES as readonly string[]).find(
      (c) => CATEGORY_COLLECTION[c as Category] === collection,
    ) as Category;
    for (const e of entries) {
      const eId = stripExt(e.id);
      const citing = verses.filter((v) =>
        (v.data.links ?? []).some((l) => l.category === category && l.targetId === eId),
      );
      paths.push({
        params: { id: eId },
        props: {
          entry: e,
          citing: citing.map((v) => ({ id: stripExt(v.id), label: `${v.data.padalam} v.${v.data.verseNumber}` })),
        },
      });
    }
  }
  return paths;
}

const { entry, citing } = Astro.props;
const d = entry.data as any;
const { Content } = await entry.render();

const workEntry = await getEntry('works', d.work);
const work = workEntry?.data as { title: string; author?: string; tradition?: string; description?: string } | undefined;
---
<BaseLayout title={d.citation}>
  <DraftBanner status={d.status} />
  {work && (
    <section class="layer work-info">
      <h2>{work.title}</h2>
      {work.author && <p><strong>Author:</strong> {work.author}</p>}
      {work.tradition && <p><strong>Tradition:</strong> {work.tradition}</p>}
      {work.description && <p>{work.description}</p>}
    </section>
  )}
  <h1>{d.citation}</h1>
  {d.transliteration && <p class="translit">{d.transliteration}</p>}
  {d.textExcerpt && <blockquote>{d.textExcerpt}</blockquote>}
  {d.translation && <p>{d.translation}</p>}
  <div class="layer"><Content /></div>
  {d.sourceUrl && <p><a href={d.sourceUrl} rel="noopener" target="_blank">Read the full text at the source ↗</a></p>}
  <p><small>License / provenance: {d.license}</small></p>
  {citing.length > 0 && (
    <section class="layer">
      <h2>Kamban verses that cite this</h2>
      <ul>{citing.map((v: any) => (<li><a href={`/verse/${v.id}`}>{v.label}</a></li>))}</ul>
    </section>
  )}
</BaseLayout>
