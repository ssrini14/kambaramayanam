---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageSlot from '../components/ImageSlot.astro';

// Key scenes of Sundara Kandam. `href` points into content where it exists;
// scenes without verses yet are marked "coming soon". `image` is the id of a
// record in the `images` collection (may not exist yet — ImageSlot falls back
// to a placeholder). Real Tanjore art drops in with zero layout change.
const scenes = [
  { image: 'hanuman-crossing-ocean', title: 'Hanuman crosses the ocean', href: '/verse/sundara-1-001' },
  { image: 'hanuman-meets-sita', title: 'Hanuman meets Sita', href: null },
  { image: 'hanuman-in-ravanas-court', title: "In Ravana's court", href: null },
  { image: 'hanuman-burns-lanka', title: 'The burning of Lanka', href: null },
  { image: 'hanuman-embraces-rama', title: 'The return to Rama', href: null },
];

// The acharya parampara honoured on the landing page (painted portraits).
// `years`: Ramanuja/Desika are traditional dates — verify before publishing.
// Uttamur Swamy (1897–1983) confirmed by the maintainer (family lineage).
// Parakala Swamy = the CURRENT Parakala Matha pontiff, the maintainer's own acharyan
// (true guru parampara). NOT the founder-era swamy — the earlier 1359–1386 dates were
// wrong for the current pontiff and have been removed. Add accession year if desired.
const acharyas = [
  { image: 'acharya-ramanuja', name: 'Shri Ramanujacharya (உடையவர்)', years: '1017–1137 CE' },
  { image: 'acharya-desikan', name: 'Srimad Vedanta Desikan', years: '1268–1369 CE' },
  { image: 'acharya-parakala', name: 'Shri Bramhatantra Swatantra Abhinava Vageesa Parakala Maha Desikan', years: 'current Parakala Matha pontiff' },
  { image: 'acharya-uttamur', name: 'Shri Uttamur Veeraraghavacharya', years: '1897–1983 CE' },
];
---
<BaseLayout title="Home">
  <section class="hero">
    <ImageSlot id="rama-pattabhishekam" label="Sri Rama Pattabhishekam" ratio="21/9" variant="hero" />
    <div class="hero-text">
      <h1>Kamba Ramayanam</h1>
      <p class="hero-lede">
        A cross-referenced study of Kamban's Tamil Ramayanam — each verse connected to the
        Valmiki Ramayana, Swami Desikan, the Divya Prabandham, the Bhagavad Gita, the
        Upanishads, and more, read through the Vishishtadvaita tradition.
      </p>
      <p class="hero-actions">
        <a class="btn" href="/search">Explore the verses →</a>
        <a class="btn btn-ghost" href="/about">About this project &amp; method</a>
      </p>
    </div>
  </section>

  <section class="home-block">
    <h2>Key scenes of Sundara Kandam</h2>
    <div class="scene-grid">
      {scenes.map((s) => (
        <article class="scene-card">
          {s.href
            ? <a href={s.href} class="scene-link"><ImageSlot id={s.image} label={s.title} ratio="4/3" /></a>
            : <ImageSlot id={s.image} label={s.title} ratio="4/3" />}
          <h3>{s.title}</h3>
          {!s.href && <span class="coming">Coming soon</span>}
        </article>
      ))}
    </div>
  </section>

  <section class="home-block">
    <h2>The Acharya Parampara</h2>
    <p class="block-lede">The teachers of the Vishishtadvaita tradition through whose vision these verses are read.</p>
    <div class="acharya-grid">
      {acharyas.map((a) => (
        <article class="acharya-card">
          <ImageSlot id={a.image} label={a.name} ratio="3/4" variant="portrait" />
          <h3>{a.name}</h3>
          {a.years && <p class="acharya-years">{a.years}</p>}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
